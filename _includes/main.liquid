<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      {% if title %}
      {{ title }} / CodeMacabre {% else %} CodeMacabre {% endif %}
    </title>
    <link rel="stylesheet" href="/styles/main.css" />
    <script src="/scripts/main.js"></script>
  </head>
  <body>
    {% render 'header', url: page.url %}
    <main class="content">
      {{ content }}
    </main>
    <footer>
      <p>
        &copy; <span id="date">2022</span>
        <span class="mail">{{ site.author.name }}</span>
      </p>
    </footer>
  </body>
</html>
