---
layout: main
title: Writing
pagination:
  data: collections.writing
  size: 10
  alias: posts
  reverse: true
---

<h2>Writing</h2>
<ul>
  {% for post in posts %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <i class="dates nobr">(written {{ post.date | date: "%d %b, %Y" }})</i>
  </li>
  {% endfor %}
</ul>

<p>
  {% if pagination.href.previous %}
  <a href="{{ pagination.href.previous }}">Previous</a>
  {% else %} <span class="inactive">Previous</span> {% endif %} / {% if
  pagination.href.next %}
  <a href="{{ pagination.href.next }}">Next</a>
  {% else %} <span class="inactive">Next</span> {% endif %}
</p>
