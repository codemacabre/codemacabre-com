---
layout: main
title: Speaking
pagination:
  data: collections.speaking
  size: 10
  alias: posts
  reverse: true
---

<h2>Speaking</h2>
<ul>
  {% for post in posts %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <i class="dates nobr">({{ post.date | date: "%d %b, %Y" }})</i>
  </li>
  {% endfor %}
</ul>

{% render 'pagination', pagination: pagination %}
