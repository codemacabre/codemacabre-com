---
layout: main
---

<h2><a href="/txt">Writing</a></h2>
<ul>
  {% assign posts = collections.writing | reverse %} {% for post in posts
  limit:5 %}
  <li>
    <a href="{{ post.url }}">{{ post.data.title }}</a>
    <i class="nobr">(written {{ post.date | date: "%d %b, %Y" }})</i>
  </li>
  {% endfor %}
</ul>

<h2><a href="/prj">Projects</a></h2>
<ul>
  {% assign projects = collections.projects | reverse %} {% for project in
  projects limit:5 %}
  <li>
    <a href="{{ project.url }}">{{ project.data.title }}</a>
    <i class="nobr">
      {{ project.date | date: "%Y" }}
      {% if project.data.endDate %} - {{ project.data.endDate | date: "%Y" }}
      {% endif %}
    </i>
  </li>
  {% endfor %}
</ul>
